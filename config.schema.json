{
    "pluginAlias": "GateAutomation",
    "pluginType": "platform",
    "singular": true,
    "schema": {
        "type": "object",
        "properties": {
            "mqttHost": {
                "title": "MQTT Host",
                "type": "string",
                "default": "localhost"
            },
            "mqttPort": {
                "title": "MQTT Port",
                "type": "integer",
                "default": 1883
            },
            "mqttUsername": {
                "title": "MQTT Username",
                "type": "string"
            },
            "mqttPassword": {
                "title": "MQTT Password",
                "type": "string"
            },
            "autoCloseEnabled": {
                "title": "Auto Close Enabled",
                "type": "boolean",
                "default": false
            },
            "autoCloseDelayMs": {
                "title": "Auto Close Delay (ms)",
                "type": "integer",
                "default": 5000
            }
        }
    }
}
