{
    "pluginAlias": "GateAutomation",
    "pluginType": "platform",
    "singular": true,
    "schema": {
        "type": "object",
        "properties": {
            "mqttHost": {
                "title": "Host",
                "type": "string",
                "default": "localhost"
            },
            "mqttPort": {
                "title": "Port",
                "type": "integer",
                "default": 1883
            },
            "mqttUsername": {
                "title": "Username",
                "type": "string"
            },
            "mqttPassword": {
                "title": "Password",
                "type": "string"
            },
            "autoCloseEnabled": {
                "title": "Enabled",
                "type": "boolean",
                "default": false
            },
            "autoCloseDelaySeconds": {
                "title": "Delay (seconds)",
                "type": "integer",
                "default": 5
            }
        }
    },
    "layout": [
        {
            "type": "section",
            "title": "MQTT",
            "items": [
                "mqttHost",
                "mqttPort",
                "mqttUsername",
                "mqttPassword"
            ]
        },
        {
            "type": "section",
            "title": "Auto Close",
            "expandable": true,
            "expanded": false,
            "items": [
                "autoCloseEnabled",
                "autoCloseDelaySeconds"
            ]
        }
    ]
}
